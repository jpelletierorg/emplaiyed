OPENROUTER_API_KEY=your-openrouter-api-key-here

# LLM Models — override any task-specific model (uses OpenRouter model IDs).
# Defaults use Gemini Flash for ~10x cost savings over Claude.
# Switch back to Claude for higher quality: anthropic/claude-sonnet-4-5, anthropic/claude-haiku-4.5
# EMPLAIYED_DEFAULT_MODEL=google/gemini-2.5-flash
# EMPLAIYED_CV_MODEL=google/gemini-2.5-flash
# EMPLAIYED_LETTER_MODEL=google/gemini-2.0-flash-001
# EMPLAIYED_SEARCH_MODEL=google/gemini-2.0-flash-001
# EMPLAIYED_SCORING_MODEL=google/gemini-2.0-flash-001
# EMPLAIYED_OUTREACH_MODEL=google/gemini-2.0-flash-001
# EMPLAIYED_PROFILE_MODEL=google/gemini-2.5-flash

# Scoring threshold — opportunities below this score are hidden from Queue.
# They are still persisted but marked BELOW_THRESHOLD. Default is 30.
# EMPLAIYED_SCORE_THRESHOLD=30

# Inbox model — cheap model for email classification (default: claude-haiku-4.5)
# EMPLAIYED_INBOX_MODEL=anthropic/claude-haiku-4.5

# Email SMTP (collected during profile build)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# Inbox Monitor — IMAP credentials for fetching incoming emails
# EMPLAIYED_IMAP_HOST=mail.example.com
# EMPLAIYED_IMAP_PORT=993
# EMPLAIYED_IMAP_USER=you@example.com
# EMPLAIYED_IMAP_PASSWORD=your-imap-password

# Inbox Monitor — Telegram bot for daily briefing notifications
# EMPLAIYED_TELEGRAM_BOT_TOKEN=your-bot-token
# EMPLAIYED_TELEGRAM_CHAT_ID=your-chat-id
